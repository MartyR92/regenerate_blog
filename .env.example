# .env.example
# ==========================================
# SECRETS MANAGEMENT
# ==========================================
# Instructions:
# 1. Copy this file and rename it to `.env`
# 2. Fill in your actual API keys below
# 3. DO NOT commit `.env` to version control! (.gitignore is already configured to block it)

# Tier 1 (Speed/Drafting) - Inception Labs
INCEPTION_API_KEY="inc-..."

# Tier 1 (Logic/Editing) - Anthropic Free Tier
ANTHROPIC_API_KEY="sk-ant-..."

# Tier 1 (Vision/Context/Heavy Lifting) - Google AI Studio (Pro-abo)
# Round-robin keys to avoid 429 limits
GEMINI_API_KEY_1="AIza..."
GEMINI_API_KEY_2=""
GEMINI_API_KEY_3=""

# Tier 2 (Universal Fallback) - OpenRouter
# Used for Llama 4 Maverick, Mistral Large 3, etc.
OPENROUTER_API_KEY_1="sk-or-v1-..."
OPENROUTER_API_KEY_2=""
OPENROUTER_API_KEY_3=""
OPENROUTER_API_KEY_4=""
OPENROUTER_API_KEY_5=""

# Optional: GitHub Token for CI/CD pushing
GITHUB_TOKEN="ghp_..."
